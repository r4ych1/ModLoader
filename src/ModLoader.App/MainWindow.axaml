<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ModLoader.App.MainWindow"
        Width="1180"
        Height="820"
        Title="ModLoader - Feature 008">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="InputRowHoverBackgroundBrush" Color="#12000000" />
          <SolidColorBrush x:Key="InputRowHoverBorderBrush" Color="#40000000" />
          <SolidColorBrush x:Key="InputRowSelectedBackgroundBrush" Color="#2a3b82f6" />
          <SolidColorBrush x:Key="InputRowSelectedBorderBrush" Color="#3b82f6" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBackgroundBrush" Color="#3d2563eb" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBorderBrush" Color="#1d4ed8" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="InputRowHoverBackgroundBrush" Color="#1f93c5fd" />
          <SolidColorBrush x:Key="InputRowHoverBorderBrush" Color="#4b93c5fd" />
          <SolidColorBrush x:Key="InputRowSelectedBackgroundBrush" Color="#334f8df5" />
          <SolidColorBrush x:Key="InputRowSelectedBorderBrush" Color="#60a5fa" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBackgroundBrush" Color="#4464a7ff" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBorderBrush" Color="#93c5fd" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Border.DropZone">
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderBrush" Value="#6b7280" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="Border.InputRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Border.InputRow:pointerover">
      <Setter Property="Background" Value="{DynamicResource InputRowHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowHoverBorderBrush}" />
    </Style>
    <Style Selector="Border.InputRow.selected">
      <Setter Property="Background" Value="{DynamicResource InputRowSelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowSelectedBorderBrush}" />
    </Style>
    <Style Selector="Border.InputRow.selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource InputRowSelectedHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowSelectedHoverBorderBrush}" />
    </Style>
  </Window.Styles>

  <DockPanel>
    <Border DockPanel.Dock="Top"
            BorderThickness="0,0,0,1"
            BorderBrush="#374151"
            Background="#0b1220"
            Padding="12,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock FontSize="20"
                     FontWeight="Bold"
                     Foreground="#e5e7eb"
                     Text="Feature 008: Profile Workspace" />
          <TextBlock Foreground="#9ca3af"
                     Text="Profiles are the only launchable unit. Select a profile on the left, then manage Source Port, IWAD, and Mods from the shared library." />
        </StackPanel>
        <Button Grid.Column="1"
                Content="Launch"
                IsEnabled="{Binding CanLaunch}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                Padding="20,8"
                Click="OnLaunchClicked" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top"
            IsVisible="{Binding HasMessage}"
            BorderBrush="#f59e0b"
            BorderThickness="1"
            Background="#1af59e0b"
            Padding="10"
            Margin="20,12,20,0">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Foreground="#92400e"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   Text="{Binding MessageText}" />
        <Button Grid.Column="1"
                Content="Delete"
                IsVisible="{Binding HasPendingDeleteConfirmation}"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Click="OnConfirmDeleteProfileClicked" />
        <Button Grid.Column="2"
                Content="Cancel"
                IsVisible="{Binding HasPendingDeleteConfirmation}"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Click="OnCancelDeleteProfileClicked" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom"
            BorderThickness="1,1,1,0"
            BorderBrush="#374151"
            Background="#111827"
            Padding="12">
      <StackPanel Spacing="6">
        <TextBlock Foreground="#d1d5db"
                   FontWeight="SemiBold"
                   Text="Command Preview" />
        <TextBox Text="{Binding CommandPreviewArguments}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Background="#0f172a"
                 Foreground="#e5e7eb"
                 BorderBrush="#4b5563"
                 BorderThickness="1"
                 FontFamily="Consolas"
                 MinHeight="56"
                 Padding="8"
                 Watermark="-iwad ... -file ..." />
      </StackPanel>
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <Grid Margin="20" ColumnDefinitions="320,*">
        <Border Grid.Column="0"
                BorderBrush="#374151"
                BorderThickness="1"
                CornerRadius="8"
                Background="#0f172a"
                Padding="12">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock FontSize="18"
                           FontWeight="Bold"
                           Foreground="#e5e7eb"
                           Text="Profiles" />
                <TextBlock Foreground="#94a3b8"
                           Text="Select, rename, delete, or create a launch profile from the current library selections." />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="New Profile"
                      IsEnabled="{Binding CanCreateProfile}"
                      VerticalAlignment="Top"
                      Click="OnNewProfileClicked" />
            </Grid>

            <ItemsControl ItemsSource="{Binding ProfileRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="InputRow"
                          Classes.selected="{Binding IsSelected}"
                          Margin="0,0,0,8"
                          Tag="{Binding Id}"
                          PointerPressed="OnProfileRowPointerPressed"
                          DoubleTapped="OnProfileRowDoubleTapped">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Spacing="6">
                        <StackPanel IsVisible="{Binding IsDisplayVisible}" Spacing="4">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock IsVisible="{Binding HasInvalidReason}"
                                     Foreground="#f59e0b"
                                     TextWrapping="Wrap"
                                     Text="{Binding InvalidReason}" />
                        </StackPanel>
                        <TextBox IsVisible="{Binding IsRenameVisible}"
                                 Tag="{Binding Id}"
                                 Text="{Binding RenameText, Mode=TwoWay}"
                                 KeyDown="OnProfileRenameKeyDown"
                                 LostFocus="OnProfileRenameLostFocus"
                                 Loaded="OnProfileRenameTextBoxLoaded" />
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  IsVisible="{Binding IsDisplayVisible}"
                                  Spacing="6"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Top">
                        <Border IsVisible="{Binding IsInvalid}"
                                Background="#44311d"
                                CornerRadius="999"
                                Padding="8,2">
                          <TextBlock Foreground="#f59e0b"
                                     FontSize="11"
                                     FontWeight="Bold"
                                     Text="INVALID" />
                        </Border>
                        <Button Content="Delete"
                                Tag="{Binding Id}"
                                HorizontalAlignment="Right"
                                Click="OnDeleteProfileClicked" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <StackPanel Grid.Column="1" Spacing="12" Margin="16,0,0,0">
          <Border BorderBrush="#374151"
                  BorderThickness="1"
                  CornerRadius="8"
                  Background="#0f172a"
                  Padding="12">
            <StackPanel Spacing="4">
              <TextBlock FontSize="18"
                         FontWeight="Bold"
                         Foreground="#e5e7eb"
                         Text="{Binding SelectedProfileName}" />
              <TextBlock Foreground="#94a3b8"
                         TextWrapping="Wrap"
                         Text="{Binding SelectedProfileStatusText}" />
            </StackPanel>
          </Border>

          <TextBlock FontWeight="SemiBold" Text="Source Port Inputs" />
          <Border Classes="DropZone"
                  DragDrop.AllowDrop="True"
                  DragDrop.DragOver="OnDropZoneDragOver"
                  DragDrop.Drop="OnSourcePortDrop">
            <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" SharedSizeGroup="SourcePortActionColumn" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Allowed: .exe. Drop one or more files. Directories are ignored."
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Clear All"
                        IsEnabled="{Binding HasSourcePorts}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Click="OnClearAllSourcePortsClicked" />
              </Grid>
              <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding SourcePortRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="InputRow"
                            Classes.selected="{Binding IsSelected}"
                            Margin="0,4,0,0"
                            Tag="{Binding Path}"
                            PointerPressed="OnSourcePortRowPointerPressed">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" SharedSizeGroup="SourcePortActionColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Path}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Remove"
                                Tag="{Binding Path}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Click="OnRemoveSourcePortClicked" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>

          <TextBlock FontWeight="SemiBold" Text="IWAD Inputs" />
          <Border Classes="DropZone"
                  DragDrop.AllowDrop="True"
                  DragDrop.DragOver="OnDropZoneDragOver"
                  DragDrop.Drop="OnIwadDrop">
            <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" SharedSizeGroup="IwadActionColumn" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Allowed: .wad, .pk3, .iwad, .ipk3, .ipk7, .pk7. Directories scan top-level files only."
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Clear All"
                        IsEnabled="{Binding HasIwads}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Click="OnClearAllIwadsClicked" />
              </Grid>
              <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding IwadRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="InputRow"
                            Classes.selected="{Binding IsSelected}"
                            Margin="0,4,0,0"
                            Tag="{Binding Path}"
                            PointerPressed="OnIwadRowPointerPressed">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" SharedSizeGroup="IwadActionColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Path}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Remove"
                                Tag="{Binding Path}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Click="OnRemoveIwadClicked" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>

          <TextBlock FontWeight="SemiBold" Text="Mod Inputs" />
          <Border Classes="DropZone"
                  DragDrop.AllowDrop="True"
                  DragDrop.DragOver="OnDropZoneDragOver"
                  DragDrop.Drop="OnModDrop">
            <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
              <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" SharedSizeGroup="ModActionColumn" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Allowed: .wad, .pwad, .pk3, .pk7, .ipk3, .ipk7, .pkz, .zip. Directories scan top-level files only."
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Clear All"
                        IsEnabled="{Binding HasMods}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Click="OnClearAllModsClicked" />
              </Grid>
              <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding ModRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="InputRow"
                            Classes.selected="{Binding IsSelected}"
                            Margin="0,4,0,0"
                            Tag="{Binding Path}"
                            PointerPressed="OnModRowPointerPressed">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" SharedSizeGroup="ModActionColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Path}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Remove"
                                Tag="{Binding Path}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Click="OnRemoveModClicked" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Grid>
          </Border>
        </StackPanel>
      </Grid>
    </ScrollViewer>
  </DockPanel>
</Window>
