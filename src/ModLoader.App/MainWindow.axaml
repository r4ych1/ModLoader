<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ModLoader.App.MainWindow"
        Width="980"
        Height="760"
        Title="ModLoader - Feature 005">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="InputRowHoverBackgroundBrush" Color="#12000000" />
          <SolidColorBrush x:Key="InputRowHoverBorderBrush" Color="#40000000" />
          <SolidColorBrush x:Key="InputRowSelectedBackgroundBrush" Color="#2a3b82f6" />
          <SolidColorBrush x:Key="InputRowSelectedBorderBrush" Color="#3b82f6" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBackgroundBrush" Color="#3d2563eb" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBorderBrush" Color="#1d4ed8" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="InputRowHoverBackgroundBrush" Color="#1f93c5fd" />
          <SolidColorBrush x:Key="InputRowHoverBorderBrush" Color="#4b93c5fd" />
          <SolidColorBrush x:Key="InputRowSelectedBackgroundBrush" Color="#334f8df5" />
          <SolidColorBrush x:Key="InputRowSelectedBorderBrush" Color="#60a5fa" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBackgroundBrush" Color="#4464a7ff" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBorderBrush" Color="#93c5fd" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Border.DropZone">
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderBrush" Value="#6b7280" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="Border.InputRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="4" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Border.InputRow:pointerover">
      <Setter Property="Background" Value="{DynamicResource InputRowHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowHoverBorderBrush}" />
    </Style>
    <Style Selector="Border.InputRow.selected">
      <Setter Property="Background" Value="{DynamicResource InputRowSelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowSelectedBorderBrush}" />
    </Style>
    <Style Selector="Border.InputRow.selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource InputRowSelectedHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowSelectedHoverBorderBrush}" />
    </Style>
  </Window.Styles>

  <DockPanel>
    <Border DockPanel.Dock="Top"
            BorderThickness="0,0,0,1"
            BorderBrush="#374151"
            Background="#0b1220"
            Padding="12,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="2">
          <TextBlock FontSize="20"
                     FontWeight="Bold"
                     Foreground="#e5e7eb"
                     Text="Feature 005: Drop Inputs + Launch" />
          <TextBlock Foreground="#9ca3af"
                     Text="Drop source-port executable, IWAD files, and Mod files. Select IWAD and ordered Mods to launch." />
        </StackPanel>
        <Button Grid.Column="1"
                Content="Launch"
                IsEnabled="{Binding CanLaunch}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                Padding="20,8"
                Click="OnLaunchClicked" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top"
            IsVisible="{Binding HasStartupWarning}"
            BorderBrush="#f59e0b"
            BorderThickness="1"
            Background="#1af59e0b"
            Padding="10"
            Margin="20,12,20,0">
      <TextBlock Foreground="#92400e"
                 FontWeight="SemiBold"
                 Text="{Binding StartupWarningMessage}" />
    </Border>

    <Border DockPanel.Dock="Bottom"
            BorderThickness="1,1,1,0"
            BorderBrush="#374151"
            Background="#111827"
            Padding="12">
      <StackPanel Spacing="6">
        <TextBlock Foreground="#d1d5db"
                   FontWeight="SemiBold"
                   Text="Command Preview" />
        <TextBox Text="{Binding CommandPreviewArguments}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Background="#0f172a"
                 Foreground="#e5e7eb"
                 BorderBrush="#4b5563"
                 BorderThickness="1"
                 FontFamily="Consolas"
                 MinHeight="56"
                 Padding="8"
                 Watermark="-iwad ... -file ..." />
      </StackPanel>
    </Border>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="20" Spacing="12">
        <TextBlock FontWeight="SemiBold" Text="Source Port (.exe only)" />
        <Border Classes="DropZone"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="OnDropZoneDragOver"
                DragDrop.Drop="OnSourcePortDrop">
          <Grid RowDefinitions="Auto,Auto">
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="Drop one or more files. Last valid .exe becomes active."
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="Clear Source Port"
                      IsEnabled="{Binding HasSourcePort}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Click="OnClearSourcePortClicked" />
            </Grid>
            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       FontWeight="SemiBold"
                       Text="{Binding SourcePortPath, FallbackValue=No source port selected}" />
          </Grid>
        </Border>

        <TextBlock FontWeight="SemiBold" Text="IWAD Inputs" />
        <Border Classes="DropZone"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="OnDropZoneDragOver"
                DragDrop.Drop="OnIwadDrop">
          <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" SharedSizeGroup="IwadActionColumn" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="Allowed: .wad, .pk3, .iwad, .ipk3, .ipk7, .pk7. Directories scan top-level files only."
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="Clear All"
                      IsEnabled="{Binding HasIwads}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Click="OnClearAllIwadsClicked" />
            </Grid>
            <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding IwadRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="InputRow"
                          Classes.selected="{Binding IsSelected}"
                          Margin="0,4,0,0"
                          Tag="{Binding Path}"
                          PointerPressed="OnIwadRowPointerPressed">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="IwadActionColumn" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Path}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <Button Grid.Column="1"
                              Content="Remove"
                              Tag="{Binding Path}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Click="OnRemoveIwadClicked" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Border>

        <TextBlock FontWeight="SemiBold" Text="Mod Inputs" />
        <Border Classes="DropZone"
                DragDrop.AllowDrop="True"
                DragDrop.DragOver="OnDropZoneDragOver"
                DragDrop.Drop="OnModDrop">
          <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" SharedSizeGroup="ModActionColumn" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                         Text="Allowed: .wad, .pwad, .pk3, .pk7, .ipk3, .ipk7, .pkz. Directories scan top-level files only."
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Content="Clear All"
                      IsEnabled="{Binding HasMods}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"
                      Click="OnClearAllModsClicked" />
            </Grid>
            <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding ModRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="InputRow"
                          Classes.selected="{Binding IsSelected}"
                          Margin="0,4,0,0"
                          Tag="{Binding Path}"
                          PointerPressed="OnModRowPointerPressed">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ModActionColumn" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Path}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <Button Grid.Column="1"
                              Content="Remove"
                              Tag="{Binding Path}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Click="OnRemoveModClicked" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
