<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ModLoader.App.MainWindow"
        Width="1180"
        Height="820"
        Title="ModLoader - Feature 009">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="InputRowHoverBackgroundBrush" Color="#12000000" />
          <SolidColorBrush x:Key="InputRowHoverBorderBrush" Color="#40000000" />
          <SolidColorBrush x:Key="InputRowSelectedBackgroundBrush" Color="#2a3b82f6" />
          <SolidColorBrush x:Key="InputRowSelectedBorderBrush" Color="#3b82f6" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBackgroundBrush" Color="#3d2563eb" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBorderBrush" Color="#1d4ed8" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="InputRowHoverBackgroundBrush" Color="#1f93c5fd" />
          <SolidColorBrush x:Key="InputRowHoverBorderBrush" Color="#4b93c5fd" />
          <SolidColorBrush x:Key="InputRowSelectedBackgroundBrush" Color="#334f8df5" />
          <SolidColorBrush x:Key="InputRowSelectedBorderBrush" Color="#60a5fa" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBackgroundBrush" Color="#4464a7ff" />
          <SolidColorBrush x:Key="InputRowSelectedHoverBorderBrush" Color="#93c5fd" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="Border.DropZone">
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderBrush" Value="#6b7280" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style Selector="Border.InputRow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Border.InputRow:pointerover">
      <Setter Property="Background" Value="{DynamicResource InputRowHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowHoverBorderBrush}" />
    </Style>
    <Style Selector="Border.InputRow.selected">
      <Setter Property="Background" Value="{DynamicResource InputRowSelectedBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowSelectedBorderBrush}" />
    </Style>
    <Style Selector="Border.InputRow.selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource InputRowSelectedHoverBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputRowSelectedHoverBorderBrush}" />
    </Style>
  </Window.Styles>

  <DockPanel>
    <Border DockPanel.Dock="Top"
            BorderThickness="0,0,0,1"
            BorderBrush="#374151"
            Background="#0b1220"
            Padding="12,10">
      <StackPanel Spacing="2">
        <TextBlock FontSize="20"
                   FontWeight="Bold"
                   Foreground="#e5e7eb"
                   Text="Feature 009: Collapsible File Library" />
        <TextBlock Foreground="#9ca3af"
                   Text="Profiles are the only launchable unit. Select a profile on the left, then manage Source Port, IWAD, and Mods from the shared library on the right." />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Top"
            IsVisible="{Binding HasMessage}"
            BorderBrush="#f59e0b"
            BorderThickness="1"
            Background="#1af59e0b"
            Padding="10"
            Margin="20,12,20,0">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Foreground="#92400e"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   Text="{Binding MessageText}" />
        <Button Grid.Column="1"
                Content="Delete"
                IsVisible="{Binding HasPendingDeleteConfirmation}"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Click="OnConfirmDeleteProfileClicked" />
        <Button Grid.Column="2"
                Content="Cancel"
                IsVisible="{Binding HasPendingDeleteConfirmation}"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Click="OnCancelDeleteProfileClicked" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Bottom"
            BorderThickness="1,1,1,0"
            BorderBrush="#374151"
            Background="#111827"
            Padding="12">
      <StackPanel Spacing="6">
        <TextBlock Foreground="#d1d5db"
                   FontWeight="SemiBold"
                   Text="Command Preview" />
        <TextBox Text="{Binding CommandPreviewArguments}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Background="#0f172a"
                 Foreground="#e5e7eb"
                 BorderBrush="#4b5563"
                 BorderThickness="1"
                 FontFamily="Consolas"
                 MinHeight="56"
                 Padding="8"
                 Watermark="-iwad ... -file ..." />
      </StackPanel>
    </Border>

    <Grid Margin="20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding ProfilePaneColumnWidth}" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="{Binding FileLibraryPaneColumnWidth}" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              BorderBrush="#374151"
              BorderThickness="1"
              CornerRadius="8"
              Background="#0f172a"
              Padding="12">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock FontSize="18"
                       FontWeight="Bold"
                       Foreground="#e5e7eb"
                       Text="Profiles" />
            <TextBlock Foreground="#94a3b8"
                       Text="Select, rename, or delete a launch profile from the saved profile list." />
          </StackPanel>

          <ScrollViewer Grid.Row="1"
                        Margin="0,12,0,0"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ProfileRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="InputRow"
                          Classes.selected="{Binding IsSelected}"
                          Margin="0,0,0,8"
                          Tag="{Binding Id}"
                          PointerPressed="OnProfileRowPointerPressed">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" Spacing="6">
                        <StackPanel IsVisible="{Binding IsDisplayVisible}" Spacing="4">
                          <TextBlock FontWeight="SemiBold"
                                     Text="{Binding Name}" />
                          <TextBlock IsVisible="{Binding HasInvalidReason}"
                                     Foreground="#f59e0b"
                                     TextWrapping="Wrap"
                                     Text="{Binding InvalidReason}" />
                        </StackPanel>
                        <TextBox IsVisible="{Binding IsRenameVisible}"
                                 Tag="{Binding Id}"
                                 Text="{Binding RenameText, Mode=TwoWay}"
                                 KeyDown="OnProfileRenameKeyDown"
                                 LostFocus="OnProfileRenameLostFocus"
                                 Loaded="OnProfileRenameTextBoxLoaded" />
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  IsVisible="{Binding IsDisplayVisible}"
                                  Spacing="6"
                                  Margin="8,0,0,0"
                                  VerticalAlignment="Top">
                        <Border IsVisible="{Binding IsInvalid}"
                                Background="#44311d"
                                CornerRadius="999"
                                Padding="8,2">
                          <TextBlock Foreground="#f59e0b"
                                     FontSize="11"
                                     FontWeight="Bold"
                                     Text="INVALID" />
                        </Border>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Right">
                          <Button Content="Launch"
                                  Tag="{Binding Id}"
                                  IsEnabled="{Binding CanLaunchProfile}"
                                  Click="OnLaunchProfileClicked" />
                          <Button Content="Rename"
                                  Tag="{Binding Id}"
                                  Click="OnRenameProfileClicked" />
                          <Button Content="Delete"
                                  Tag="{Binding Id}"
                                  Click="OnDeleteProfileClicked" />
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Column="2"
              IsVisible="{Binding IsFileLibraryPaneExpanded}"
              BorderBrush="#374151"
              BorderThickness="1"
              CornerRadius="8"
              Background="#0f172a"
              Padding="12">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
            <Button Grid.Column="0"
                    Content="{Binding FileLibraryPaneToggleText}"
                    VerticalAlignment="Top"
                    Padding="12,6"
                    Click="OnToggleFileLibraryPaneCollapsedClicked" />
            <TextBlock Grid.Column="1"
                       Margin="12,0,0,0"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#e5e7eb"
                       VerticalAlignment="Center"
                       Text="File Library" />
          </Grid>

          <ScrollViewer Grid.Row="1"
                        Margin="0,12,0,0"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
              <Border BorderBrush="#374151"
                      BorderThickness="1"
                      CornerRadius="8"
                      Background="#111827"
                      Padding="12">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock FontSize="18"
                               FontWeight="Bold"
                               Foreground="#e5e7eb"
                               Text="{Binding SelectedProfileName}" />
                    <TextBlock Foreground="#94a3b8"
                               TextWrapping="Wrap"
                               Text="{Binding SelectedProfileStatusText}" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Content="New Profile"
                          IsEnabled="{Binding CanCreateProfile}"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                          Margin="12,0,0,0"
                          Click="OnNewProfileClicked" />
                </Grid>
              </Border>

              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             Text="Source Port Inputs" />
                  <Button Grid.Column="1"
                          Content="{Binding SourcePortSectionToggleText}"
                          Click="OnToggleSourcePortSectionCollapsedClicked" />
                </Grid>
                <Border Classes="DropZone"
                        IsVisible="{Binding AreSourcePortRowsVisible}"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="OnDropZoneDragOver"
                        DragDrop.Drop="OnSourcePortDrop">
                  <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="Allowed: .exe. Drop one or more files. Directories are ignored."
                               VerticalAlignment="Center" />
                    <ItemsControl Grid.Row="1"
                                  Margin="0,8,0,0"
                                  ItemsSource="{Binding SourcePortRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="InputRow"
                                  Classes.selected="{Binding IsSelected}"
                                  Margin="0,4,0,0"
                                  Tag="{Binding Path}"
                                  PointerPressed="OnSourcePortRowPointerPressed">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="SourcePortActionColumn" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0"
                                         Text="{Binding Path}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                              <Button Grid.Column="1"
                                      Content="Remove"
                                      Tag="{Binding Path}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Click="OnRemoveSourcePortClicked" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             Text="IWAD Inputs" />
                  <Button Grid.Column="1"
                          Content="{Binding IwadSectionToggleText}"
                          Click="OnToggleIwadSectionCollapsedClicked" />
                </Grid>
                <Border Classes="DropZone"
                        IsVisible="{Binding AreIwadRowsVisible}"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="OnDropZoneDragOver"
                        DragDrop.Drop="OnIwadDrop">
                  <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="Allowed: .wad, .pk3, .iwad, .ipk3, .ipk7, .pk7. Directories scan top-level files only."
                               VerticalAlignment="Center" />
                    <ItemsControl Grid.Row="1"
                                  Margin="0,8,0,0"
                                  ItemsSource="{Binding IwadRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="InputRow"
                                  Classes.selected="{Binding IsSelected}"
                                  Margin="0,4,0,0"
                                  Tag="{Binding Path}"
                                  PointerPressed="OnIwadRowPointerPressed">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="IwadActionColumn" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0"
                                         Text="{Binding Path}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                              <Button Grid.Column="1"
                                      Content="Remove"
                                      Tag="{Binding Path}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Click="OnRemoveIwadClicked" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             Text="Mod Inputs" />
                  <Button Grid.Column="1"
                          Content="{Binding ModSectionToggleText}"
                          Click="OnToggleModSectionCollapsedClicked" />
                </Grid>
                <Border Classes="DropZone"
                        IsVisible="{Binding AreModRowsVisible}"
                        DragDrop.AllowDrop="True"
                        DragDrop.DragOver="OnDropZoneDragOver"
                        DragDrop.Drop="OnModDrop">
                  <Grid Grid.IsSharedSizeScope="True" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0"
                               Text="Allowed: .wad, .pwad, .pk3, .pk7, .ipk3, .ipk7, .pkz, .zip. Directories scan top-level files only."
                               VerticalAlignment="Center" />
                    <ItemsControl Grid.Row="1"
                                  Margin="0,8,0,0"
                                  ItemsSource="{Binding ModRows}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Classes="InputRow"
                                  Classes.selected="{Binding IsSelected}"
                                  Margin="0,4,0,0"
                                  Tag="{Binding Path}"
                                  PointerPressed="OnModRowPointerPressed">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ModActionColumn" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Grid.Column="0"
                                         Text="{Binding Path}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                              <Button Grid.Column="1"
                                      Content="Remove"
                                      Tag="{Binding Path}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Click="OnRemoveModClicked" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </Grid>
                </Border>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Column="2"
              IsVisible="{Binding IsFileLibraryPaneCollapsed}"
              BorderBrush="#374151"
              BorderThickness="1"
              CornerRadius="8"
              Background="#0f172a"
              Padding="8">
        <StackPanel Spacing="10">
          <Button Content="{Binding FileLibraryPaneToggleText}"
                  HorizontalAlignment="Stretch"
                  Padding="6,4"
                  Click="OnToggleFileLibraryPaneCollapsedClicked" />
          <TextBlock Foreground="#e5e7eb"
                     FontWeight="Bold"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     Text="File Library" />
        </StackPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
